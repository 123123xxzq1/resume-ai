# ============================================================
# OpenAI / LLM
# ============================================================
# 必填：OpenAI API Key，获取：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选：自定义 OpenAI 兼容端点（国内代理 / DeepSeek / Moonshot）
# OPENAI_BASE_URL=https://api.openai.com/v1
# 可选：指定模型，默认 gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# ============================================================
# 站点 URL —— 生产环境必填
# 用于 sitemap / robots / RSS / OG / 支付回调拼接
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# Supabase —— 用户系统 & 数据库
# 获取：https://app.supabase.com 创建项目 → Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# Service Role Key（保密，只在服务端使用，绕过 RLS）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ============================================================
# Stripe —— 海外支付
# 获取：https://dashboard.stripe.com/apikeys
# ============================================================
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Webhook Signing Secret —— 在 Stripe Dashboard 的 Webhook 页面创建后获取
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe 价格 ID（在 Stripe Products 里创建产品后获取）
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_LIFETIME=price_xxx

# ============================================================
# ZPay / 易支付协议 —— 国内微信/支付宝代收
# 兼容：zpay.com.cn、彩虹易支付、码支付 等
# ============================================================
# 商户 ID
ZPAY_PID=
# 商户密钥（签名用）
ZPAY_KEY=
# 网关地址（不同服务商不同，默认 zpay）
ZPAY_GATEWAY=https://z-pay.cn
